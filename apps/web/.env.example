# =============================================================================
# Shipyard Web (apps/web) 環境変数
# =============================================================================
#
# このファイルは Git にコミットされます(値は入れない)。
# 実際の値は `apps/web/.env.local` にコピーして設定してください。
# .env.local は .gitignore で除外されています。
#
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk(認証)
# -----------------------------------------------------------------------------
# 取得方法:
#   1. https://clerk.com にサインアップ
#   2. Application を作成し、Dashboard の "API keys" から取得
#
# Publishable key はクライアント(ブラウザ)側に公開される。
# NEXT_PUBLIC_ プレフィックスは Next.js が公開を許可する印。
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key はサーバー側のみで使用。漏洩厳禁。
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk のリダイレクト先(任意 / デフォルトは / )
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# -----------------------------------------------------------------------------
# API(apps/api / NestJS)
# -----------------------------------------------------------------------------
# Server Component / Route Handler から apps/api を呼ぶときのベース URL。
# サーバー側でのみ使うので NEXT_PUBLIC_ プレフィックスは付けない。
# ローカル: http://localhost:4000、本番: ECS の API エンドポイント
API_URL=http://localhost:4000
