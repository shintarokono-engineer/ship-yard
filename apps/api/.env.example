# =============================================================================
# Shipyard API (apps/api) 環境変数
# =============================================================================
# このファイルは Git にコミットされます(値は入れない)。
# 実際の値は `apps/api/.env.local` にコピーして設定してください。
# .env.local は .gitignore で除外されています。
# =============================================================================

# データベース接続(docker-compose.yml の postgres コンテナ)
# Prisma Client がランタイムで読む。packages/db/.env と同じ値。
DATABASE_URL=postgresql://shipyard:shipyard@localhost:5432/shipyard?schema=public

# Clerk(認証)— サーバー側シークレットキー(JWT 検証に使用)
# https://clerk.com の Application Dashboard → API keys から取得。漏洩厳禁。
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Stripe(決済 / Subscriptions、ADR-004)
# -----------------------------------------------------------------------------
# シークレットキー: https://dashboard.stripe.com の「開発者 → API キー」から取得(テストモードは sk_test_)。漏洩厳禁。
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook 署名シークレット。ローカルは `stripe listen --forward-to localhost:4000/webhooks/stripe`
# の出力(whsec_...)、本番は Dashboard の Webhook エンドポイント登録時に取得。
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# プラン別の Price ID。Dashboard「商品カタログ」で作成した継続(Recurring)Price の ID(price_...)。
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AI(Anthropic Claude、ADR-005)
# -----------------------------------------------------------------------------
# https://console.anthropic.com の API キーから取得。漏洩厳禁。
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# OpenAI(embedding 専用、text-embedding-3-small、ADR-005)
# -----------------------------------------------------------------------------
# https://platform.openai.com/api-keys から取得(`sk-proj-...` 始まり)。Billing で事前チャージが必要($5 推奨)。
# embedding 失敗時は AI 生成自体は成功扱いにし、後で `pnpm --filter @shipyard/api backfill:embeddings` で取り戻す。
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# アプリ URL
# -----------------------------------------------------------------------------
# Checkout 完了 / キャンセル時のリダイレクト先ベース URL(apps/web)。ローカルは http://localhost:3000
APP_BASE_URL=http://localhost:3000

# API がリッスンするポート(デフォルト 4000)
PORT=4000
