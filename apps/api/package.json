{
  "name": "@shipyard/api",
  "version": "0.0.1",
  "private": true,
  "description": "Shipyard バックエンド(NestJS)",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "type-check": "tsc --noEmit",
    "backfill:embeddings": "ts-node --transpile-only -P tsconfig.json scripts/backfill-embeddings.ts",
    "seed-corpus:apply": "ts-node --transpile-only -P tsconfig.json scripts/seed-corpus.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@clerk/backend": "^1.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@shipyard/db": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dayjs": "^1.11.20",
    "openai": "^6.37.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.12.3",
    "rxjs": "^7.8.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
