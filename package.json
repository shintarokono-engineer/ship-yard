{
  "name": "shipyard",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "個人開発者および小規模開発チーム向けの AI 支援付きプロジェクト管理 SaaS",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @shipyard/api dev",
    "dev:web": "pnpm --filter @shipyard/web dev",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck:api": "pnpm --filter @shipyard/api type-check",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:studio": "pnpm --filter @shipyard/db studio",
    "db:migrate": "pnpm --filter @shipyard/db migrate:dev",
    "db:gen": "pnpm --filter @shipyard/db generate",
    "db:setup": "pnpm --filter @shipyard/db generate && pnpm --filter @shipyard/db build",
    "backfill": "pnpm --filter @shipyard/api backfill:embeddings"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "eslint": "^9.15.0",
    "typescript-eslint": "^8.15.0",
    "prettier": "^3.3.0",
    "eslint-config-prettier": "^9.1.0",
    "@next/eslint-plugin-next": "^15.0.0"
  }
}
