# =============================================================================
# Shipyard DB (packages/db) 環境変数
# =============================================================================
# このファイルは Git にコミットされます(値は入れない)。
# 実際の値は `packages/db/.env` にコピーして設定してください。
# .env は .gitignore で除外されています。
#
# 用途: Prisma CLI(prisma generate / migrate / studio)が読みます。
# NestJS ランタイムは別途 apps/api 側で DATABASE_URL を解決します。
# =============================================================================

# ローカル開発用(docker-compose.yml の postgres コンテナに接続)
# - user: shipyard / pass: shipyard / db: shipyard / port: 5432
DATABASE_URL=postgresql://shipyard:shipyard@localhost:5432/shipyard?schema=public
