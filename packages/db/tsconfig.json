{
  // ルート tsconfig.base.json を継承
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // packages/db は apps/api(CommonJS)からも apps/web からも import されるため、
    // dist/ に JS + .d.ts を出力して「コンパイル済みパッケージ」として配布する。
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,

    // pnpm の symlink 構造下で IDE 側の TS Server が @types を auto-discovery
    // できない事象を回避するため明示
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
