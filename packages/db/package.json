{
  "name": "@shipyard/db",
  "version": "0.0.1",
  "private": true,
  "description": "Shipyard データベース層(Prisma スキーマと Client)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "prisma generate && tsc",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "prisma-erd-generator": "^2.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
