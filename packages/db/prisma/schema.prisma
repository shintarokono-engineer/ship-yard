// Shipyard データベーススキーマ
//
// 出典: docs/data-model.md(SSoT)
// マルチテナント方針: ADR-002(Pool model、tenantId 自動注入)
// ベクトル検索方針: ADR-005(pgvector + HNSW + cosine、text-embedding-3-small 1536 次元)

generator client {
  provider        = "prisma-client-js"
  // pgvector 拡張(ADR-005、RAG 用)を Prisma 側でも認識させるための preview
  previewFeatures = ["postgresqlExtensions"]
}

// schema 変更時に Mermaid 形式の ER 図(Markdown)を自動生成。
// docs/data-model-erd.generated.md は GitHub 上でインラインレンダーされ、
// VS Code でも Markdown プレビューで Mermaid 図として表示される。
//
// docs/data-model.md の手動 Mermaid セクションが SSoT(セマンティックなラベル付き)、
// 本ファイルは schema との整合性を保証する補助資料。
generator erd {
  provider = "prisma-erd-generator"
  output   = "../../../docs/data-model-erd.generated.md"
  theme    = "neutral"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector 拡張を Prisma migrate が自動で CREATE EXTENSION してくれる
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ============================================================================
// Enums
// ============================================================================

/// テナントの課金プラン(ADR-004)
enum Plan {
  /// 無料プラン
  FREE
  /// 個人開発者向け有料プラン
  PRO
  /// 小規模チーム向け
  TEAM
}

/// テナントメンバーの権限ロール(6 種)
enum Role {
  /// オーナー: テナントの全権限。プラン変更・削除・所有権譲渡が可能
  OWNER
  /// 管理者: メンバー招待・削除・ロール変更が可能(プラン変更は不可)
  ADMIN
  /// 開発者: プロジェクト・チェックリスト・ProjectDocument の作成編集が可能
  DEVELOPER
  /// レビュアー: コメント・レビュー操作のみ。本文編集は不可
  REVIEWER
  /// テスター: テスト・バグ報告用の閲覧+コメント権限
  TESTER
  /// 閲覧者: 閲覧のみ。書き込み一切不可
  VIEWER
}

/// プロジェクトのライフサイクル状態
enum ProjectStatus {
  /// アイデア段階(着手前)
  IDEA
  /// 開発中
  IN_DEV
  /// ベータ公開中(限定ユーザーに開放)
  BETA
  /// 一般公開済み
  LAUNCHED
  /// アーカイブ済み(凍結、編集不可)
  ARCHIVED
}

/// チェックリスト項目の状態
enum ItemStatus {
  /// 未着手
  TODO
  /// 着手中
  IN_PROGRESS
  /// 完了
  DONE
  /// 該当なし(プロジェクト特性により不要と判断)
  NOT_APPLICABLE
}

/// チェックリスト項目のカテゴリ
enum Category {
  /// 技術: 実装・テスト・インフラ・セキュリティ
  TECH
  /// 法務: 利用規約・プライバシーポリシー・特商法表記
  LEGAL
  /// マーケティング: SEO・告知文・SNS 投稿・PR
  MARKETING
  /// UX: ユーザビリティ・アクセシビリティ・オンボーディング
  UX
  /// その他
  OTHER
}

/// ProjectDocument の種別(AI 生成・ユーザー手動作成のいずれも対象)
enum DocType {
  /// プロジェクトの README
  README
  /// ランディングページ本文
  LANDING_PAGE
  /// リリースブログ記事
  RELEASE_BLOG
  /// X / Twitter 告知文
  TWEET
  /// Product Hunt 投稿用テキスト
  PRODUCT_HUNT
  /// 告知メール本文
  EMAIL
  /// その他
  OTHER
}

/// AI 利用機能の種別(AIUsage の集計軸、ADR-005)
enum Feature {
  /// @deprecated ADR-013 で PRODUCT_DIAGNOSIS に統合済(新規実装では PRODUCT_DIAGNOSIS を使う)。
  /// PostgreSQL の `ALTER TYPE DROP VALUE` 非サポートのため schema から削除はしない。
  COMPETITOR_RESEARCH
  /// ドキュメント自動生成(README / LP / 告知文、Sonnet 4)
  DRAFT_GEN
  /// タスク分解(Tool Use、Haiku 4.5)
  TASK_SPLIT
  /// 過去ドキュメント RAG による QA 応答(Sonnet 4)
  RAG_QA
  /// リリース前チェックリスト生成(Tool Use、Haiku 4.5)
  CHECKLIST_GEN
  /// 既存ドキュメントの文章推敲(append-only で新版作成、Sonnet 4 + Tool Use)
  REFINE_DOC
  /// プロダクト診断(競合調査 + サービスレベルスコア化、Sonnet 4 + Web Search Tool + Tool Use、ADR-013)
  PRODUCT_DIAGNOSIS
  /// アイデア検証(発案段階の Problem-Solution Fit 検証、Sonnet 4 + Web Search Tool + Tool Use、ADR-013 改訂版)
  IDEA_VALIDATION
  /// その他の AI 機能
  OTHER
}

/// RagQaMessage の発話者種別(ADR-005 Day 27 改訂)
enum RagQaRole {
  /// ユーザーからの質問
  USER
  /// AI からの回答
  ASSISTANT
}

/// Stripe Subscription の状態(Stripe の status をミラー)
enum SubStatus {
  /// 課金中・正常
  ACTIVE
  /// 支払い遅延中(リトライ中)
  PAST_DUE
  /// 解約済み
  CANCELED
  /// 初回支払い未完了
  INCOMPLETE
  /// トライアル期間中
  TRIALING
}

/// Stripe Webhook の処理状態
enum WebhookStatus {
  /// 正常に処理完了
  PROCESSED
  /// 処理失敗(リトライ上限到達)
  FAILED
  /// リトライ中
  RETRYING
}

// ============================================================================
// Models
// ============================================================================

/// アプリケーションユーザー。Clerk からミラーされる。
/// 複数のテナントに所属可能(TenantMember 経由)で、テナントには属さない例外モデル。
model User {
  /// 内部 ID(cuid)
  id          String   @id @default(cuid())
  /// Clerk のユーザー ID。Clerk Webhook 受信時の同期キー
  clerkUserId String   @unique
  /// メールアドレス。連絡用(ログイン認証は Clerk 側で実施)
  email       String   @unique
  /// 表示名(任意、Clerk 側のプロフィール変更で更新)
  name        String?
  /// アバター画像 URL(任意、Clerk から取得)
  image       String?
  /// ユーザー作成日時(Clerk からの初回 Webhook 受信時)
  createdAt   DateTime @default(now())

  memberships     TenantMember[]
  ownedTenants    Tenant[]          @relation("TenantOwner")
  documents       ProjectDocument[]
  usage           AIUsage[]
  invitations     InvitationToken[]
  ragQaSessions   RagQaSession[]
  serviceScores   ServiceScore[]
  ideaValidations IdeaValidation[]
}

/// ワークスペース(テナント)。マルチテナント分離の基本単位(ADR-002)。
/// Pool model のため、ほぼ全業務テーブルが tenantId で本モデルを参照する。
model Tenant {
  /// 内部 ID(cuid)
  id        String   @id @default(cuid())
  /// URL 用の人間可読 ID(`/w/{slug}`、ADR-003)。英数字+ハイフン、3〜30 文字
  slug      String   @unique
  /// ワークスペース表示名
  name      String
  /// 現在の課金プラン(Subscription と同期)
  plan      Plan     @default(FREE)
  /// オーナー User ID。プラン変更・削除・所有権譲渡の権限を持つ
  ownerId   String
  /// ワークスペース作成日時
  createdAt DateTime @default(now())

  owner           User              @relation("TenantOwner", fields: [ownerId], references: [id])
  members         TenantMember[]
  projects        Project[]
  subscription    Subscription?
  usage           AIUsage[]
  invitations     InvitationToken[]
  ragQaSessions   RagQaSession[]
  landingPages    LandingPage[]
  serviceScores   ServiceScore[]
  ideaValidations IdeaValidation[]

  @@index([slug])
}

/// テナントとユーザーの所属関係(多対多の中間テーブル)。
/// ロールはここで管理。Free プランは 3 メンバーまでサーバ側で検証。
model TenantMember {
  /// 所属テナント ID(複合 PK の一部)
  tenantId String
  /// メンバー User ID(複合 PK の一部)
  userId   String
  /// 権限ロール(6 種、デフォルトは DEVELOPER)
  role     Role     @default(DEVELOPER)
  /// 加入日時(招待受諾日 or オーナー時はテナント作成日)
  joinedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId])
  @@index([userId])
}

/// プロジェクト(個人開発 1 件 = 1 レコード)。
/// チェックリスト・ProjectDocument の親エンティティ。
model Project {
  /// 内部 ID(cuid)
  id          String        @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、Prisma Client Extension で自動注入)
  tenantId    String
  /// プロジェクト名
  name        String
  /// 概要(Markdown 可、任意)
  description String?       @db.Text
  /// 想定ユーザー(誰の課題か、ADR-013 改訂版「2 モード化」 で追加)。アイデア検証で必須、プロダクト診断でも参照。
  targetUsers      String?       @db.Text
  /// 解きたい課題(ADR-013 改訂版で追加)。Lean Startup の Problem-Solution Fit 検証の中核。
  problemStatement String?       @db.Text
  /// 想定機能リスト(Markdown 可、ADR-013 改訂版で追加)。アイデア段階で書き出し、実装で更新する想定。
  proposedFeatures String?       @db.Text
  /// 想定価格モデル(例「Free + Pro ¥980/月」、ADR-013 改訂版で追加)。差別化軸の評価精度向上。
  pricingModel     String?
  /// ライフサイクル状態(IDEA / IN_DEV / BETA / LAUNCHED / ARCHIVED)
  status      ProjectStatus @default(IDEA)
  /// リリース予定日 or 実績日(任意)
  launchDate  DateTime?
  /// 作成者 User ID
  createdById String
  /// 作成日時
  createdAt   DateTime      @default(now())
  /// 最終更新日時(Prisma 自動更新)
  updatedAt   DateTime      @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklist        ChecklistItem[]
  documents        ProjectDocument[]
  ragQaSessions    RagQaSession[]
  landingPage      LandingPage?
  serviceScores    ServiceScore[]
  ideaValidations  IdeaValidation[]

  @@index([tenantId])
  @@index([tenantId, status])
}

/// プロジェクトに紐付くリリース前チェックリスト項目。
/// AI が `CHECKLIST_GEN` 機能で自動生成、ユーザーが手動追加・編集も可能。
model ChecklistItem {
  /// 内部 ID(cuid)
  id          String     @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId    String
  /// 所属プロジェクト ID
  projectId   String
  /// 親 ChecklistItem の ID(TASK_SPLIT で分解された子サブタスクのみセット、手動作成では null)。
  /// 親が削除されたら子も Cascade で削除(意図しない一括削除リスクはあるが、ユーザー選択で許容)。
  parentId    String?
  /// 項目カテゴリ(TECH / LEGAL / MARKETING / UX / OTHER)
  category    Category
  /// 項目タイトル(短文)
  title       String
  /// 詳細説明(Markdown 可、任意)
  description String?    @db.Text
  /// 進捗状態(TODO / IN_PROGRESS / DONE / NOT_APPLICABLE)
  status      ItemStatus @default(TODO)
  /// 並び順(同一プロジェクト内で昇順表示、手動並び替え対応)
  position    Int        @default(0)
  /// 作成日時
  createdAt   DateTime   @default(now())

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   ChecklistItem?  @relation("ChecklistSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks ChecklistItem[] @relation("ChecklistSubtasks")

  @@index([tenantId])
  @@index([projectId, position])
  @@index([parentId])
}

/// AI が生成 or ユーザーが編集した文書(README / LP / 告知文 等)。
/// embedding は RAG 検索用、同 tenant の過去文書を context に注入する独自性の核(ADR-005)。
model ProjectDocument {
  /// 内部 ID(cuid)
  id          String                       @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId    String
  /// 所属プロジェクト ID
  projectId   String
  /// 文書タイプ(README / LANDING_PAGE / RELEASE_BLOG / TWEET 等)
  type        DocType
  /// 文書タイトル
  title       String
  /// Markdown 本文
  content     String                       @db.Text
  /// 推敲履歴用バージョン番号(同一 (projectId, type) 内で v1, v2, ... と増加。一意制約あり)
  version     Int                          @default(1)
  /// text-embedding-3-small の 1536 次元ベクトル(RAG 検索用、HNSW インデックス)
  embedding   Unsupported("vector(1536)")?
  /// 作成者 User ID
  createdById String
  /// 作成日時
  createdAt   DateTime                     @default(now())
  /// 論理削除日時(NULL = 生存)。物理削除はせず、ここに UTC now を入れて非表示化する(append-only ポリシー)。
  /// 一覧/取得は常に `where: { deletedAt: null }` を付ける。
  deletedAt   DateTime?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  /// 同一プロジェクト・同一タイプ内で version は一意(並行生成時の version 重複を DB レベルで防止)。
  /// 注: deletedAt は含めない。soft delete 後の version 再利用は許さず、欠番を許して常にインクリメント続行する
  /// (例: v3 を soft delete → 次の新版は v4。v3 を作り直さない)
  @@unique([projectId, type, version])
  @@index([tenantId])
  /// 一覧クエリの絞り込み(deletedAt IS NULL + projectId + type)を支援する partial index は
  /// `migrations/20260514130000_partial_index_for_active_documents/migration.sql` で raw SQL 管理。
  /// Prisma schema は partial index を表現できないため、HNSW と同じパターンで Prisma 管理外にしている
  /// (今後 `prisma migrate diff` が「未知の index」として DROP 提案するが、手作業で除外する)。
}

/// プロジェクトの公開ランディングページ(ADR-009)。
/// ProjectDocument(Markdown + append-only + 非公開)とは性質が異なるため専用テーブルに分離。
/// ブロック型 JSON を mutable に編集し、publishedAt で公開状態を管理する。
model LandingPage {
  /// 内部 ID(cuid)
  id          String    @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId    String
  /// 所属プロジェクト ID(1 プロジェクト = 1 LP、ユニーク制約)
  projectId   String    @unique
  /// ブロック配列(hero / features / stats / testimonial / cta / footer、ADR-009 のブロックスキーマ)
  blocks      Json
  /// カラーテーマ(プリセット、ADR-009 Phase 5a)。アクセント色のみを切り替える。不正値は描画側で default 扱い
  theme       String    @default("default")
  /// 公開日時(null = 非公開 / 値あり = 公開中)。公開 URL `/p/{slug}/{projectId}` の表示可否を決める
  publishedAt DateTime?
  /// 作成日時
  createdAt   DateTime  @default(now())
  /// 最終更新日時(mutable 編集、append-only ではない)
  updatedAt   DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// プロダクト診断(PRODUCT_DIAGNOSIS)の結果(ADR-013)。
/// 1 プロジェクトに複数件の診断履歴を持ち、`createdAt` で時系列比較できる。
/// 競合データと AI 採点の理由は Json で snapshot 保存(参照先 URL が後で変わっても履歴的事実を保つ、
/// RagQaMessage.references パターンの踏襲)。
model ServiceScore {
  /// 内部 ID(cuid)
  id             String   @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId       String
  /// 所属プロジェクト ID
  projectId      String
  /// 総合スコア(0-100、breakdown の 5 軸合計 = totalScore で整合性を保つ)。
  /// アプリ層で Tool Use 応答パース直後に整合性アサート、不一致は AIBadResponseError(502)で保存しない。
  totalScore     Int
  /// 5 軸ブレークダウン(differentiation / targetClarity / featureCompleteness /
  /// releaseReadiness / competitiveAdvantage、各 0-20 + コメント)
  breakdown      Json
  /// 改善提案 3〜5 件(priority / title / body / axis)
  suggestions    Json
  /// 競合プロダクトのスナップショット(name / url / summary / similarityNote)。
  /// Web Search 失敗時 / Free フォールバック時は空配列を保存。
  competitorRefs Json
  /// Web Search Tool を使ったか(Web Search 無効 / 失敗時は false)。
  webSearchUsed  Boolean
  /// 使用したモデル ID(AIUsage.model と一致、ai.constants.ts の AI_MODEL_SONNET の値)
  modelUsed      String
  /// 診断実行者 User ID
  createdById    String
  /// 診断実行日時(履歴順、最新が表示の主軸)
  createdAt      DateTime @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  /// 履歴比較画面で「最新 N 件を新しい順」 を高速取得するため
  @@index([projectId, createdAt])
}

/// アイデア検証(IDEA_VALIDATION)の結果(ADR-013 改訂版「2 モード化」)。
/// `Project.status = IDEA` のときに実行する Lean Startup の Problem-Solution Fit 検証機能。
/// `ServiceScore` と並ぶ独立機能で、評価軸も異なる(機能完成度・リリース準備度の代わりに
/// 問題明確性・市場性を評価)。`recommendation` で GO / PIVOT / NO_GO の意思決定支援を返す。
model IdeaValidation {
  /// 内部 ID(cuid)
  id             String   @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId       String
  /// 所属プロジェクト ID
  projectId      String
  /// 総合スコア(0-100、breakdown の 5 軸合計 = totalScore で整合性アサート)
  totalScore     Int
  /// 意思決定支援('GO' | 'PIVOT' | 'NO_GO')。Lean Startup の Problem-Solution Fit 判定。
  /// LLM が rubric + 競合データに基づいて文字列で返す(enum 化は将来検討、現状は柔軟性重視)
  recommendation String
  /// 5 軸ブレークダウン(problemClarity / targetClarity / differentiation /
  /// competitiveAdvantage / marketPotential、各 0-20 + コメント)
  breakdown      Json
  /// 改善提案 3〜5 件(priority / title / body / axis)、ServiceScore.suggestions と同型
  suggestions    Json
  /// 競合プロダクトのスナップショット(name / url / summary / similarityNote)、
  /// Web Search で取得した実競合の参照、ServiceScore.competitorRefs と同型
  competitorRefs Json
  /// Web Search Tool を使ったか(Free フォールバック / 失敗時は false)
  webSearchUsed  Boolean
  /// 使用したモデル ID(AIUsage.model と一致、ai.constants.ts の AI_MODEL_SONNET の値)
  modelUsed      String
  /// 検証実行者 User ID
  createdById    String
  /// 検証実行日時(履歴順、最新が表示の主軸)
  createdAt      DateTime @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  /// 履歴比較画面で「最新 N 件を新しい順」 を高速取得するため
  @@index([projectId, createdAt])
}

/// AI API 呼び出しのテナント単位ログ。
/// AI クレジット制(ADR-012)の月次上限判定とコスト集計に使用(ADR-005)。
model AIUsage {
  /// 内部 ID(cuid)
  id        String   @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId  String
  /// 利用者 User ID
  userId    String
  /// 使用モデル ID(例: `claude-sonnet-4-7` / `claude-haiku-4-5-20251001`)
  model     String
  /// 利用機能種別(集計の主軸)
  feature   Feature
  /// 入力トークン数
  tokensIn  Int
  /// 出力トークン数
  tokensOut Int
  /// 推定コスト(円、為替換算済み、小数 4 桁精度)
  costJpy   Decimal  @db.Decimal(10, 4)
  /// AI クレジット消費数(Haiku 4.5=1cr、Sonnet 4=3cr、embedding 等の Feature.OTHER=0cr)。
  /// ADR-012 のプラン別月次上限判定に使う(Pro 300/月、Team 800/seat/月)。
  credits   Int      @default(0)
  /// 利用日時
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, feature, createdAt])
}

/// Stripe Subscription の DB ミラー(テナント 1:1)。
/// Webhook で更新される。Free プランでも stripeCustomerId は確保(将来の課金切替を高速化)。
model Subscription {
  /// 内部 ID(cuid)
  id               String    @id @default(cuid())
  /// 紐付くテナント ID(1:1 関係、ユニーク制約)
  tenantId         String    @unique
  /// Stripe Customer ID(Free プランでも作成、ユニーク)
  stripeCustomerId String    @unique
  /// Stripe Subscription ID(Free プラン時は null、ユニーク)
  stripeSubId      String?   @unique
  /// 現在のプラン(Tenant.plan と同期)
  plan             Plan
  /// 課金状態(ACTIVE / PAST_DUE / CANCELED / INCOMPLETE / TRIALING)
  status           SubStatus @default(ACTIVE)
  /// 課金数量(Team プランのメンバー数 = Stripe Subscription Quantity、ADR-012)。
  /// AI クレジット計算(Team の上限 = quantity × 800 cr)はこの列を真実の源にし、Webhook 受信時に同期される。
  /// Pro / Free は常に 1 で運用(quantity 概念はあるが意味なし)。
  quantity         Int       @default(1)
  /// 現課金期間終了日(次回更新基準、Stripe からの情報)
  currentPeriodEnd DateTime?
  /// 解約申請日時(7 日 grace → 30 日凍結 → 削除フローの起点、ADR-004)
  canceledAt       DateTime?
  /// レコード作成日時
  createdAt        DateTime  @default(now())
  /// 最終更新日時(Webhook 受信ごとに更新)
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// Stripe Webhook の受信ログ。Idempotency 担保とトラブルシューティングに使用(ADR-004)。
/// テナントを持たない例外モデル(Webhook 受信時点では tenantId 未確定のため)。
model WebhookEvent {
  /// 内部 ID(cuid)
  id            String        @id @default(cuid())
  /// Stripe イベント ID(Idempotency Key、ユニーク制約で重複処理を構造的に防止)
  stripeEventId String        @unique
  /// イベントタイプ(例: `checkout.session.completed` / `invoice.paid`)
  type          String
  /// 受信ペイロード全体(監査・再処理用)
  payload       Json
  /// 処理状態(PROCESSED / FAILED / RETRYING)
  status        WebhookStatus @default(PROCESSED)
  /// 処理完了日時
  processedAt   DateTime      @default(now())

  @@index([type, processedAt])
}

/// RAG_QA(壁打ち)の会話セッション(ADR-005 Day 27 改訂)。
/// 1 プロジェクト内に複数セッション持てる。対話履歴を DB に永続化することで
/// 「壁打ちログを資産化」 する Shipyard §1 提供価値を直接実現する。
model RagQaSession {
  /// 内部 ID(cuid)
  id          String   @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須)
  tenantId    String
  /// 所属プロジェクト ID(壁打ちは特定プロジェクト文脈で行う)
  projectId   String
  /// セッションタイトル(初期は user-provided or 「新しい会話」、v1.x で初回質問から自動生成予定)
  title       String
  /// セッション作成者 User ID
  createdById String
  /// セッション作成日時
  createdAt   DateTime @default(now())
  /// 最終更新日時(メッセージ追加ごとに更新、一覧の並び替え軸)
  updatedAt   DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id])
  messages  RagQaMessage[]

  @@index([tenantId])
  @@index([projectId, updatedAt])
}

/// RagQaSession 内の 1 メッセージ(ADR-005 Day 27 改訂)。
/// 1 セッションあたり 100 メッセージ上限(暴走防止)、1 メッセージあたり content 最大 8000 文字(DTO で制約)
model RagQaMessage {
  /// 内部 ID(cuid)
  id        String    @id @default(cuid())
  /// 所属テナント ID(マルチテナント分離キー、必須、session.tenantId と一致)
  tenantId  String
  /// 所属セッション ID
  sessionId String
  /// 発話者種別(USER = ユーザー質問、ASSISTANT = AI 回答)
  role      RagQaRole
  /// メッセージ本文(Markdown 可)
  content   String    @db.Text
  /// 入力トークン数(ASSISTANT のみ、USER は null)
  tokensIn  Int?
  /// 出力トークン数(ASSISTANT のみ、USER は null)
  tokensOut Int?
  /// この回答が参照した過去ドキュメント(RAG ヒット)のスナップショット(ADR-005 Day 27 改訂)。
  /// ASSISTANT のみ非 null。`{ id, projectId, type, title, isSeed, distance }[]` 形式。
  /// 参照先が後で編集 / 削除されても「この回答が何を見たか」 の履歴的事実を保つためスナップショット保存(正規化しない)。
  references Json?
  /// 作成日時
  createdAt DateTime  @default(now())

  session RagQaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId, createdAt])
}

/// メンバー招待トークン。`/invite/{token}` の URL を生成し、メールで送信。
/// 同一メールへの重複招待は既存トークンを更新する想定。
model InvitationToken {
  /// 内部 ID(cuid)
  id          String    @id @default(cuid())
  /// 招待先テナント ID
  tenantId    String
  /// 招待先メールアドレス
  email       String
  /// 招待時に付与するロール(OWNER 以外を選択可)
  role        Role      @default(DEVELOPER)
  /// 招待リンク用トークン(URL に埋め込む、ユニーク、暗号学的乱数を推奨)
  token       String    @unique
  /// 有効期限(発行から 7 日)
  expiresAt   DateTime
  /// 受諾日時(null = 未受諾)
  acceptedAt  DateTime?
  /// 取り消し日時(null = 未取り消し)。論理削除で履歴を残す(誰がいつ取り消したかの追跡用)
  revokedAt   DateTime?
  /// 招待者 User ID
  invitedById String

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation(fields: [invitedById], references: [id])

  @@index([tenantId, email])
  @@index([token])
}
